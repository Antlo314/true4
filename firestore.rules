rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public can SUBMIT only — never read, never edit.
    // Only the signed-in admin (created in Firebase Auth → Users)
    // can read and update statuses.

    match /inquiries/{doc} {
      allow create: if isValidSubmission(1600);
      allow read, update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /questions/{doc} {
      allow create: if isValidSubmission(1200);
      allow read, update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    function isValidSubmission(maxLen) {
      let d = request.resource.data;
      return d.message is string && d.message.size() > 0 && d.message.size() <= maxLen
        && d.name is string && d.name.size() <= 80
        && d.contact is string && d.contact.size() <= 120
        && d.type is string && d.type.size() <= 24
        && d.status == 'new';
    }
  }
}
